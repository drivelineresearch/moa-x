{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MoA Final Plan Lineage",
  "description": "Machine-readable companion to final-plan.md. It records which proposer steps and refiner findings support each aggregated step so report.html can explain how the final plan was formed.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "title", "summary", "confidence", "steps", "rejected_inputs"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "rationale"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "description",
          "files_touched",
          "decision",
          "adjudication",
          "proposer_refs",
          "refiner_refs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{0,63}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "files_touched": {
            "type": "array",
            "items": {"type": "string"}
          },
          "decision": {
            "type": "string",
            "enum": ["accepted", "revised", "new"]
          },
          "adjudication": {
            "type": "string",
            "minLength": 1
          },
          "proposer_refs": {
            "type": "array",
            "items": {"$ref": "#/$defs/proposerRef"}
          },
          "refiner_refs": {
            "type": "array",
            "items": {"$ref": "#/$defs/refinerRef"}
          }
        }
      }
    },
    "rejected_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["proposer", "step_index", "reason", "refiner_refs"],
        "properties": {
          "proposer": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{0,31}$"
          },
          "step_index": {
            "type": "integer",
            "minimum": 0
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "refiner_refs": {
            "type": "array",
            "items": {"$ref": "#/$defs/refinerRef"}
          }
        }
      }
    }
  },
  "$defs": {
    "proposerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "step_index", "relationship", "note"],
      "properties": {
        "agent_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,31}$"
        },
        "step_index": {
          "type": "integer",
          "minimum": 0
        },
        "relationship": {
          "type": "string",
          "enum": ["adopted", "adapted"]
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "refinerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "kind", "index", "note"],
      "properties": {
        "agent_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,31}$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "verification",
            "missing_step",
            "incorrect_step",
            "disagreement",
            "synthesis_recommendation"
          ]
        },
        "index": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

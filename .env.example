# MoA-X harness env overrides — copy to .env to activate.
#
# Every MOA_* var here has a built-in default. Settings in this file
# lose to shell-exported vars but win over harness/config.yaml.
#
# Built-in harnesses: {codex, claude, opencode, cursor}. Built-in named
# providers: codex, sonnet, glm, kimi, qwen, composer. Add more via the
# MOA_PROVIDER_<NAME> shorthand below or the providers: block in config.yaml.
#
# CLI flags to run_moa.py override everything below.

# --- binary paths -----------------------------------------------------------
# Override only if the CLI is not on PATH or lives at a non-default location.
# MOA_CODEX_BIN=/usr/local/bin/codex
# MOA_CLAUDE_BIN=/usr/local/bin/claude
# MOA_OPENCODE_BIN=/usr/local/bin/opencode
# MOA_CURSOR_BIN=/usr/local/bin/cursor-agent   # binary is cursor-agent (older) or agent (newer)

# --- models -----------------------------------------------------------------
# MOA_CODEX_MODEL=gpt-5.4
# MOA_SONNET_MODEL=claude-sonnet-4-6
# MOA_GLM_MODEL=opencode-go/glm-5.2
# MOA_KIMI_MODEL=opencode-go/kimi-k2.7-code
# MOA_QWEN_MODEL=qwen-token-plan/qwen3.7-max
# Run GLM / Kimi through Zhipu/Moonshot direct instead of the opencode-go gateway:
# MOA_GLM_MODEL=zhipuai/glm-5.2
# MOA_KIMI_MODEL=moonshotai/kimi-k2.7-code
# Or through Fireworks serverless:
# MOA_GLM_MODEL=fireworks-ai/accounts/fireworks/models/glm-5p2
# MOA_KIMI_MODEL=fireworks-ai/accounts/fireworks/models/kimi-k2p7-code

# --- provider API keys ------------------------------------------------------
# Claude reads ANTHROPIC_API_KEY directly. OpenCode reads whichever provider
# key is set; no `opencode auth login` is needed for those providers.
# ANTHROPIC_API_KEY=...   # Sonnet via Claude Code CLI
# ZHIPU_API_KEY=...       # GLM via Zhipu / Z.ai (incl. GLM Coding Plan)
# MOONSHOT_API_KEY=...    # Kimi via Moonshot
# FIREWORKS_API_KEY=...   # GLM / Kimi via Fireworks serverless
# QWEN_TOKEN_PLAN_API_KEY=sk-sp-...  # Qwen Token Plan (dedicated key)
# CURSOR_API_KEY=sk-...   # cursor API-billed mode (else: cursor-agent login)

# --- codex reasoning effort -------------------------------------------------
# One of: low, medium, high, xhigh.
# MOA_CODEX_EFFORT=high

# --- per-agent timeouts (seconds) -------------------------------------------
# Codex default scales with effort: xhigh=1500, high=1200, med/low=900.
# opencode + cursor + sonnet default to 1200.
# MOA_CODEX_TIMEOUT=1500
# MOA_SONNET_TIMEOUT=1200
# MOA_OPENCODE_TIMEOUT=1200
# MOA_CURSOR_TIMEOUT=1200
# Per-named-provider timeout: MOA_<NAME>_TIMEOUT (e.g. MOA_GLM_TIMEOUT=1500)

# --- layer / role selection -------------------------------------------------
# Comma-separated lists. Defaults run codex+glm+sonnet proposers and
# codex+kimi refiners (four labs; refiners independent of the Opus aggregator).
# MOA_PROPOSERS=codex,glm,sonnet
# MOA_REFINERS=codex,kimi
# MOA_SKIP_LAYER2=1   # set to skip refinement entirely

# --- user-named providers (shell/.env shorthand) ----------------------------
# Define a provider inline as MOA_PROVIDER_<NAME>=<harness>:<model>, then add
# <name> (lowercased, _ → -) to MOA_PROPOSERS / MOA_REFINERS. A full roster
# swap needs no config.yaml. YAML `providers:` wins on a name conflict.
#   MOA_PROVIDER_GLM_FW=opencode:fireworks-ai/accounts/fireworks/models/glm-5p2
#   MOA_PROVIDER_COMPOSER=cursor:composer-2.5
#   MOA_PROVIDER_CURSOR_GROK=cursor:grok-4.3
# Qwen Token Plan is already built in as `qwen`; add it to a layer with:
#   MOA_PROPOSERS=codex,glm,sonnet,qwen
# then, e.g.:
#   MOA_PROPOSERS=codex,glm-fw,sonnet,cursor-grok
#   MOA_REFINERS=codex,kimi
# Override a named provider's model at runtime via MOA_<NAME>_MODEL, where
# <NAME> is the provider name uppercased with - replaced by _
# (e.g. MOA_CURSOR_GROK_MODEL=grok-4.20).

# MoA-X harness env overrides — copy to .env to activate.
#
# Every MOA_* var here has a built-in default. Settings in this file
# lose to shell-exported vars but win over harness/config.yaml.
#
# Supported providers are {codex, claude-code, gemini}. Adding another
# provider requires code changes — this file cannot alone.
#
# CLI flags to run_moa.py override everything below.

# --- binary paths -----------------------------------------------------------
# Override only if the CLI is not on PATH or lives at a non-default location.
# MOA_CODEX_BIN=/usr/local/bin/codex
# MOA_GEMINI_BIN=/usr/local/bin/gemini
# MOA_CLAUDE_BIN=/usr/local/bin/claude

# --- models -----------------------------------------------------------------
# MOA_CODEX_MODEL=gpt-5.4
# MOA_GEMINI_MODEL=gemini-2.5-pro
# MOA_SONNET_MODEL=claude-sonnet-4-6

# --- codex reasoning effort -------------------------------------------------
# One of: low, medium, high, xhigh.
# MOA_CODEX_EFFORT=high

# --- per-agent timeouts (seconds) -------------------------------------------
# Codex default scales with effort: xhigh=1500, high=1200, med/low=900.
# Gemini + sonnet default to 1200.
# MOA_CODEX_TIMEOUT=1500
# MOA_GEMINI_TIMEOUT=1200
# MOA_SONNET_TIMEOUT=1200

# --- layer / role selection -------------------------------------------------
# Comma-separated lists. Defaults run all three proposers and both non-
# Anthropic refiners (codex+gemini).
# MOA_PROPOSERS=codex,gemini,sonnet
# MOA_REFINERS=codex,gemini
# MOA_SKIP_LAYER2=1   # set to skip refinement entirely

# --- cursor CLI (optional fourth provider) ---------------------------------
# MOA_CURSOR_BIN=/Users/you/.local/bin/cursor-agent
# MOA_CURSOR_TIMEOUT=1200
# CURSOR_API_KEY=sk-...    # only if using API-billed mode (else: cursor-agent login)

# --- user-named providers ---------------------------------------------------
# Define under `providers:` in harness/config.yaml. Override their model
# at runtime via MOA_<NAME>_MODEL where <NAME> is the provider name
# uppercased with - replaced by _.
#   providers:
#     cursor-grok: {harness: cursor, model: grok-4-20}
# overridable as:
#   MOA_CURSOR_GROK_MODEL=grok-4.21
